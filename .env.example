# =============================================================================
# Predictive Maintenance System — Master Environment Variables Reference
# =============================================================================
# This file is SAFE TO COMMIT — it contains only placeholders.
# Copy the relevant section into each service's own .env file and fill in real values.
# All .env files are listed in .gitignore and must NEVER be committed.
# =============================================================================


# ── backend/.env ─────────────────────────────────────────────────────────────

# Supabase (get from: https://supabase.com → Project Settings → API)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# AI microservice URL
# Local dev: http://localhost:8000
# Railway:   https://your-ai-service.railway.app
AI_SERVICE_URL=http://localhost:8000

# LLM providers (backend only — never put these in frontend)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ANTHROPIC_URL=https://api.deepseek.com/anthropic
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Email alerts (optional)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
ALERT_EMAIL_TO=alerts@yourcompany.com
ALERT_EMAIL_FROM=system@yourcompany.com

# Server settings
PORT=3001
NODE_ENV=production
# Comma-separated, NO spaces. Add your Vercel domain once deployed.
# Example: http://localhost:5173,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://YOUR_VERCEL_DOMAIN.vercel.app


# ── frontend/.env ─────────────────────────────────────────────────────────────
# (Only VITE_* vars are safe — they are bundled into the client JS)

# Local dev:   http://localhost:3001/api
# Production:  https://your-backend.railway.app/api
VITE_API_URL=http://localhost:3001/api


# ── ai-service/.env ───────────────────────────────────────────────────────────

PORT=8000
# Local dev:   *
# Production:  https://your-backend.railway.app
CORS_ORIGINS=*
